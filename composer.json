{
  "name": "verseles/sevenzip",
  "description": "A package to compress and decompress files using 7zip",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Hélio Oliveira",
      "email": "open@helio.me"
    }
  ],
  "require": {
    "php": ">=8.2",
    "symfony/process": "^7.0"
  },
  "require-dev": {
    "laravel/pint": "^1.18",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.1"
  },
  "autoload": {
    "psr-4": {
      "Verseles\\SevenZip\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Verseles\\SevenZip\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit tests/SevenZipTest.php --testdox --display-warnings --color=always",
    "test:coverage": "vendor/bin/phpunit tests/SevenZipTest.php --coverage-text --coverage-html=coverage",
    "lint": "vendor/bin/pint",
    "lint:check": "vendor/bin/pint --test",
    "analyse": "vendor/bin/phpstan analyse",
    "ci": [
      "@lint:check",
      "@analyse",
      "@test"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
